# Copy to .env and fill in real values. Never commit or upload the filled-in .env
# into public_html — Apache serves that folder as static files.

# ---- App ----
NODE_ENV=development
APP_PORT=3000

# ---- MySQL ----
# On cPanel this is almost always localhost, and user/db names carry the
# cPanel account prefix, e.g. myaccount_bisleri.
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASS=
MYSQL_DB=

# ---- Auth ----
JWT_SECRET=
JWT_EXPIRES_IN=1h

# ---- Stripe ----
STRIPE_SECRET_KEY=
